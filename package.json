{
  "name": "expresto",
  "version": "0.1.0",
  "description": "Express framework with hooks, auth, monitoring, scheduler, and websocket support",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "keywords": [
    "express",
    "middleware",
    "typescript",
    "security",
    "hooks",
    "metrics"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tmatzke1905/expresto.git"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./middleware.config.schema.json": "./middleware.config.schema.json"
  },
  "files": [
    "dist/",
    "middleware.config.schema.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "nodemon",
    "build": "NODE_ENV=production tsup",
    "build:dev": "NODE_ENV=development tsup",
    "start": "node ./dist/index.js ./middleware.config.prod.json",
    "start:dev": "ts-node src/index.ts ./middleware.config.json",
    "start:prod": "node ./dist/index.js ./middleware.config.prod.json",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "validate": "ts-node src/cli.ts",
    "test": "vitest run",
    "test:package": "vitest run tests/package/package-smoke.test.ts",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "sonar:scan": "npx @sonar/scan"
  },
  "author": "Thomas Matzke",
  "license": "MIT",
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jose": "^6.2.1",
    "log4js": "^6.9.1",
    "node-cron": "^4.2.1",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.3",
    "@opentelemetry/api": "^1.9.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
